# ─────────────────────────────────────────────
# Server Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

PORT=5000

# MongoDB Connection String
# Get free cluster at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Email Settings (for contact form notifications)
# Use Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_TO=rajeshmerndev@gmail.com

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
